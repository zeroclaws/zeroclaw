{
  "name": "zeroclaw",
  "version": "0.1.0",
  "description": "Lightweight open-source AI agent runtime for Linux/VPS machines.",
  "type": "module",
  "bin": {
    "zeroclaw": "./dist/modules/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/app/main.ts",
    "dev:cli": "tsx src/modules/cli/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/main.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "check": "npm run typecheck && npm run build"
  },
  "keywords": [
    "ai-agent",
    "telegram-bot",
    "linux",
    "vps",
    "openai-compatible"
  ],
  "author": "zeroclaws",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "grammy": "^1.38.4",
    "zod": "^4.1.13"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.4.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
